#!/usr/bin/env bash
# Enforce DCO Signed-off-by trailer on every commit.
# Local repo hook — installed via `git config core.hooksPath .githooks`.

commit_msg_file="$1"

# Allow merge commits (no sign-off required for git-generated merges).
if git rev-parse -q --verify MERGE_HEAD >/dev/null 2>&1; then
  exit 0
fi

if grep -E '^Signed-off-by: .+ <.+@.+>' "$commit_msg_file" >/dev/null 2>&1; then
  exit 0
fi

cat >&2 <<'EOF'
Missing Signed-off-by trailer.

DC0 (DCO check) requires a Signed-off-by line in every commit message.
Use `git commit -s` to add it automatically, or include this trailer
manually:

    Signed-off-by: Your Name <you@example.com>

This is a DCO (Developer Certificate of Origin) attestation, separate
from GPG commit signing.
EOF
exit 1
